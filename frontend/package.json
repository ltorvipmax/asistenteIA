{
  "name": "mi-asistente-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "setup:deps:win": "powershell -ExecutionPolicy Bypass -File .\\setup-frontend-deps.ps1",
    "dev": "powershell -ExecutionPolicy Bypass -File .\\run-vite.ps1",
    "build": "powershell -ExecutionPolicy Bypass -File .\\run-vite.ps1 build",
    "preview": "powershell -ExecutionPolicy Bypass -File .\\run-vite.ps1 preview",
    "build:railway": "vite build",
    "start": "serve -s dist -l ${PORT:-3000}"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "serve": "^14.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "vite": "^5.0.0"
  }
}
